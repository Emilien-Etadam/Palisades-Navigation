<Window x:Class="Palisades.View.EditCalendarPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Calendar Palisade" Height="320" Width="400" MinHeight="280" MinWidth="380"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Text="Palisade Title" Grid.Row="0" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" Margin="0,0,0,15" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="Days to show" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox Grid.Row="3" Margin="0,0,0,15" Text="{Binding DaysToShow, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="View mode" Grid.Row="4" Margin="0,0,0,5"/>
        <ComboBox x:Name="ViewModeCombo" Grid.Row="5" Margin="0,0,0,15"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
