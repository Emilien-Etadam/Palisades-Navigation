<Window x:Class="Palisades.View.EditCalendarPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit calendar palisade" Height="320" Width="400" MinHeight="280" MinWidth="380"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Text="Palisade Title" Grid.Row="0" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox Grid.Row="1" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="Days to show" Grid.Row="2" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox Grid.Row="3" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding DaysToShow, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="View mode" Grid.Row="4" Style="{StaticResource PalisadeDialogLabel}"/>
        <ComboBox x:Name="ViewModeCombo" Grid.Row="5" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogComboBox}"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Style="{StaticResource PalisadeDialogButton}" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Style="{StaticResource PalisadeDialogButton}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
