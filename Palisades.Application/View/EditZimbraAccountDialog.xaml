<Window x:Class="Palisades.View.EditZimbraAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Zimbra Account" Height="340" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Email" Grid.Row="0" Margin="0,0,0,4"/>
        <TextBox x:Name="EmailTextBox" Grid.Row="1" Margin="0,0,0,6" TextChanged="EmailTextBox_TextChanged"/>
        <Button x:Name="DetectOvhButton" Grid.Row="2" Content="Detect OVH (fill server from email)" Margin="0,0,0,8" Click="DetectOvhButton_Click" HorizontalAlignment="Left"/>
        <TextBlock Text="Server (CalDAV host)" Grid.Row="3" Margin="0,0,0,4"/>
        <TextBox x:Name="ServerTextBox" Grid.Row="4" Margin="0,0,0,6"/>
        <TextBlock Text="CalDAV Base URL" Grid.Row="5" Margin="0,0,0,4"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="6" Margin="0,0,0,6"/>
        <TextBlock Text="IMAP Host (for Mail Palisade)" Grid.Row="7" Margin="0,0,0,4"/>
        <TextBox x:Name="ImapHostTextBox" Grid.Row="8" Margin="0,0,0,6"/>
        <TextBlock Text="Password" Grid.Row="9" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="10" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
