<Window x:Class="Palisades.View.TaskPalisadeSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task palisade settings" Height="350" Width="400" MinHeight="350" MinWidth="400"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <!-- Sync Interval -->
        <TextBlock Text="Sync Interval (minutes)" Grid.Row="0" Style="{StaticResource PalisadeDialogLabel}"/>
        <Slider x:Name="SyncIntervalSlider" Grid.Row="1" Minimum="1" Maximum="60"
                Value="5" TickFrequency="5" TickPlacement="BottomRight"
                AutoToolTipPlacement="BottomRight" IsSnapToTickEnabled="True"/>

        <!-- Enable Logging -->
        <CheckBox x:Name="EnableLoggingCheckBox" Grid.Row="2" Margin="0,15,0,10"
                 Content="Enable detailed logging" Style="{StaticResource PalisadeDialogCheckBox}"/>

        <!-- Show Completed Tasks -->
        <CheckBox x:Name="ShowCompletedCheckBox" Grid.Row="3" Margin="0,0,0,10"
                 Content="Show completed tasks" Style="{StaticResource PalisadeDialogCheckBox}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Style="{StaticResource PalisadeDialogButton}" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Style="{StaticResource PalisadeDialogButton}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
