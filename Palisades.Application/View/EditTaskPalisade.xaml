<Window x:Class="Palisades.View.EditTaskPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Palisades.View"
        mc:Ignorable="d"
        Title="Edit Task Palisade" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Palisade Title" Grid.Row="0" Margin="0,0,0,5"/>
        <TextBox x:Name="PalisadeTitleTextBox" Grid.Row="1" Margin="0,0,0,15" 
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- CalDAV URL -->
        <TextBlock Text="CalDAV Server URL" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="3" Margin="0,0,0,15" 
                 Text="{Binding CalDAVUrl, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Username -->
        <TextBlock Text="Username" Grid.Row="4" Margin="0,0,0,5"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="5" Margin="0,0,0,15" 
                 Text="{Binding CalDAVUsername, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <TextBlock Text="Password" Grid.Row="6" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,15" 
                    Password="{Binding CalDAVPassword, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Task List ID -->
        <TextBlock Text="Task List ID" Grid.Row="8" Margin="0,0,0,5"/>
        <TextBox x:Name="TaskListIdTextBox" Grid.Row="9" Margin="0,0,0,15" 
                 Text="{Binding TaskListId, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Colors section -->
        <TextBlock Text="Header Color" Grid.Row="10" Margin="0,15,0,5"/>
        <StackPanel Grid.Row="11" Orientation="Horizontal">
            <Rectangle Width="30" Height="20" Fill="{Binding HeaderColor}" Margin="0,0,10,0"/>
            <Button Content="Change Header Color" Click="ChangeHeaderColor_Click"/>
        </StackPanel>

        <TextBlock Text="Body Color" Grid.Row="12" Margin="0,15,0,5"/>
        <StackPanel Grid.Row="13" Orientation="Horizontal">
            <Rectangle Width="30" Height="20" Fill="{Binding BodyColor}" Margin="0,0,10,0"/>
            <Button Content="Change Body Color" Click="ChangeBodyColor_Click"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>