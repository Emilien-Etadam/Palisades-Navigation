<Window x:Class="Palisades.View.EditTaskPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Task Palisade" Height="450" Width="500" MinHeight="450" MinWidth="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Loaded="Window_Loaded">

    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

        <!-- Title -->
        <TextBlock Text="Palisade Title" Grid.Row="0" Margin="0,0,0,5"/>
        <TextBox x:Name="PalisadeTitleTextBox" Grid.Row="1" Margin="0,0,0,15"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- CalDAV URL -->
        <TextBlock Text="CalDAV Server URL" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="3" Margin="0,0,0,15"
                 Text="{Binding CalDAVUrl, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Username -->
        <TextBlock Text="Username" Grid.Row="4" Margin="0,0,0,5"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="5" Margin="0,0,0,15"
                 Text="{Binding CalDAVUsername, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <TextBlock Text="Password" Grid.Row="6" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,15"/>

        <!-- Task List ID -->
        <TextBlock Text="Task List ID" Grid.Row="8" Margin="0,0,0,5"/>
        <TextBox x:Name="TaskListIdTextBox" Grid.Row="9" Margin="0,0,0,15"
                 Text="{Binding TaskListId, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
