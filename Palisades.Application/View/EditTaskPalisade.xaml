<Window x:Class="Palisades.View.EditTaskPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Task Palisade" Height="450" Width="500" MinHeight="450" MinWidth="500"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

        <!-- Title -->
        <TextBlock Text="Palisade Title" Grid.Row="0" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="PalisadeTitleTextBox" Grid.Row="1" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogTextBox}"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- CalDAV URL -->
        <TextBlock Text="CalDAV Server URL" Grid.Row="2" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="3" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogTextBox}"
                 Text="{Binding CalDAVUrl, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Username -->
        <TextBlock Text="Username" Grid.Row="4" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="5" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogTextBox}"
                 Text="{Binding CalDAVUsername, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <TextBlock Text="Password" Grid.Row="6" Style="{StaticResource PalisadeDialogLabel}"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogPasswordBox}"/>

        <!-- Task List ID -->
        <TextBlock Text="Task List ID" Grid.Row="8" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="TaskListIdTextBox" Grid.Row="9" Margin="0,0,0,15" Style="{StaticResource PalisadeDialogTextBox}"
                 Text="{Binding TaskListId, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Style="{StaticResource PalisadeDialogButton}" Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" IsDefault="True" Style="{StaticResource PalisadeDialogButton}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
