<Window x:Class="Palisades.View.ManageSnapshotsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Palisades.Properties"
        Title="{x:Static properties:Strings.WindowTitleManageLayouts}"
        Height="420" Width="640"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="{x:Static properties:Strings.LayoutNameSavedList}" FontWeight="SemiBold" Foreground="{DynamicResource PalisadeTextBrush}" Margin="0,0,0,8"/>
        <ListBox x:Name="SnapshotsListBox" Grid.Row="1" Margin="0,0,0,10" Style="{StaticResource PalisadeDialogListBox}" SelectionChanged="SnapshotsListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <TextBlock Foreground="{DynamicResource PalisadeSubtleBrush}" Margin="0,0,12,0">
                                <Run Text="{Binding CreatedAt, StringFormat=\{0:g\}}"/>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource PalisadeSubtleBrush}" Margin="0,0,12,0">
                                <Run Text="{Binding ScreenWidth}"/>
                                <Run Text="{x:Static properties:Strings.ScreenDimensionsSeparator}"/>
                                <Run Text="{Binding ScreenHeight}"/>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource PalisadeSubtleBrush}" Text="{Binding Entries.Count, StringFormat={x:Static properties:Strings.ManageSnapshotsPalisadeCountFormat}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="{x:Static properties:Strings.ButtonRestore}" Tag="{Binding Id}" Style="{StaticResource PalisadeDialogButton}" Click="RestoreButton_Click" Margin="0,0,4,0"/>
                            <Button Content="{x:Static properties:Strings.ButtonRename}" Tag="{Binding Id}" Style="{StaticResource PalisadeDialogButton}" Click="RenameButton_Click" Margin="0,0,4,0"/>
                            <Button Content="{x:Static properties:Strings.ButtonDelete}" Tag="{Binding Id}" Style="{StaticResource PalisadeDialogButton}" Click="DeleteButton_Click"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static properties:Strings.ButtonExport}" Style="{StaticResource PalisadeDialogButton}" Click="ExportButton_Click" Margin="0,0,8,0"/>
            <Button Content="{x:Static properties:Strings.ButtonImport}" Style="{StaticResource PalisadeDialogButton}" Click="ImportButton_Click" Margin="0,0,8,0"/>
            <Button Content="{x:Static properties:Strings.ButtonClose}" Style="{StaticResource PalisadeDialogButton}" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
