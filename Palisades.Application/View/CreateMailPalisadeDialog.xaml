<Window x:Class="Palisades.View.CreateMailPalisadeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create Mail Palisade" Height="520" MinHeight="520" Width="420" MinWidth="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Text="Title" Grid.Row="0" Margin="0,0,0,4"/>
        <TextBox x:Name="PalisadeTitleTextBox" Grid.Row="1" Margin="0,0,0,8" Text="{Binding PalisadeTitle, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="IMAP Host" Grid.Row="2" Margin="0,0,0,4"/>
        <TextBox x:Name="ImapHostTextBox" Grid.Row="3" Margin="0,0,0,8" Text="{Binding ImapHost, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. imap.example.com"/>
        <TextBlock Text="Username (email)" Grid.Row="4" Margin="0,0,0,4"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="5" Margin="0,0,0,8" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="Password" Grid.Row="6" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,8" PasswordChanged="PasswordBox_PasswordChanged"/>
        <Button x:Name="TestButton" Grid.Row="8" Content="Test connection &amp; load folders" Margin="0,0,0,8" Click="TestButton_Click" HorizontalAlignment="Left"/>
        <TextBlock Text="Folders to monitor (select from list after test)" Grid.Row="9" Margin="0,0,0,4"/>
        <ListBox x:Name="FoldersListBox" Grid.Row="10" Margin="0,0,0,8" SelectionMode="Multiple"/>
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock Text="Display:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="DisplayModeCombo" Width="140" Margin="0,0,10,0" SelectedIndex="0">
                <ComboBoxItem Content="Count only"/>
                <ComboBoxItem Content="Count and subjects"/>
            </ComboBox>
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button x:Name="CreateButton" Content="Create" Width="80" IsDefault="True" Click="CreateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
