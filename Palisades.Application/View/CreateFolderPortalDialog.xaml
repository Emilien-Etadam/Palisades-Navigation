<Window x:Class="Palisades.View.CreateFolderPortalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="New Folder Portal"
        Width="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="25" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title input -->
        <StackPanel Grid.Row="0">
            <Label Style="{StaticResource MaterialDesignLabel}" FontSize="18" Padding="0,0,0,5">Portal Title</Label>
            <TextBox x:Name="TitleTextBox"
                     Style="{StaticResource MaterialDesignTextBox}"
                     FontSize="16"
                     Text="My Folder Portal" />
        </StackPanel>

        <!-- Folder path -->
        <StackPanel Grid.Row="2">
            <Label Style="{StaticResource MaterialDesignLabel}" FontSize="18" Padding="0,0,0,5">Root Folder</Label>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PathTextBox"
                         Grid.Column="0"
                         Style="{StaticResource MaterialDesignTextBox}"
                         FontSize="14"
                         IsReadOnly="True" />
                <Button Grid.Column="2"
                        Content="Browse..."
                        Click="BrowseButton_Click"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        FontSize="14" />
            </Grid>
        </StackPanel>

        <!-- Validation message -->
        <TextBlock x:Name="ValidationMessage"
                   Grid.Row="4"
                   Foreground="#FFFF6666"
                   FontSize="13"
                   Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Click="CancelButton_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    FontSize="14"
                    Margin="0,0,10,0" />
            <Button Content="Create"
                    Click="CreateButton_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    FontSize="14" />
        </StackPanel>
    </Grid>
</Window>
