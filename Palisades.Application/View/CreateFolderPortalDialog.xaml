<Window x:Class="Palisades.View.CreateFolderPortalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Palisades.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Strings.WindowTitleNewBrowsePalisade}"
        Width="450"
        SizeToContent="Height"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="25" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title input -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="{x:Static properties:Strings.LabelTitle}" Style="{StaticResource PalisadeDialogLabel}" FontSize="18" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox"
                     Style="{StaticResource PalisadeDialogTextBox}"
                     FontSize="16"
                     Text="{x:Static properties:Strings.DefaultBrowsePalisadeTitle}" />
        </StackPanel>

        <!-- Folder path -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="{x:Static properties:Strings.LabelRootFolder}" Style="{StaticResource PalisadeDialogLabel}" FontSize="18" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PathTextBox"
                         Grid.Column="0"
                         Style="{StaticResource PalisadeDialogTextBox}"
                         FontSize="14"
                         IsReadOnly="True" />
                <Button Grid.Column="2"
                        Content="{x:Static properties:Strings.ButtonBrowse}"
                        Click="BrowseButton_Click"
                        Style="{StaticResource PalisadeDialogButton}"
                        FontSize="14" />
            </Grid>
        </StackPanel>

        <!-- Validation message -->
        <TextBlock x:Name="ValidationMessage"
                   Grid.Row="4"
                   Foreground="#FFFF6666"
                   FontSize="13"
                   Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static properties:Strings.ButtonCancel}"
                    Click="CancelButton_Click"
                    Style="{StaticResource PalisadeDialogButton}"
                    FontSize="14"
                    Margin="0,0,10,0" />
            <Button Content="{x:Static properties:Strings.ButtonCreate}"
                    Click="CreateButton_Click"
                    Style="{StaticResource PalisadeDialogButton}"
                    FontSize="14" />
        </StackPanel>
    </Grid>
</Window>
