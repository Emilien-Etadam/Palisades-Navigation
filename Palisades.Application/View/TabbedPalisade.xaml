<Window x:Class="Palisades.View.TabbedPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:Palisades.ViewModel"
        xmlns:helpers="clr-namespace:Palisades.Helpers"
        xmlns:converters="clr-namespace:Palisades.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
        xmlns:model="clr-namespace:Palisades.Model"
        xmlns:pal="clr-namespace:Palisades"
        xmlns:properties="clr-namespace:Palisades.Properties"
        helpers:WindowBackdrop.IsEnabled="True"
        helpers:WindowSinker.AlwaysOnBottom="True"
        ShowInTaskbar="False"
        Title="{x:Static properties:Strings.AppNamePalisades}"
        Width="{Binding Width, Mode=OneWay}"
        Height="{Binding Height, Mode=OneWay}"
        Left="{Binding X, Mode=OneWay}"
        Top="{Binding Y, Mode=OneWay}"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0" NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:PathToImageConverter x:Key="PathToImage" />
            <converters:MultiValueEqualityConverter x:Key="MultiValueEqualityConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <helpers:BindingProxy x:Key="proxy" Data="{Binding Members[0]}" />

            <!-- Onglets dans la barre de titre (Flat / Rounded selon CurrentTabHeaderButtonStyle) -->
            <Style x:Key="FlatTabHeaderButtonStyle" TargetType="Button">
                <Setter Property="Margin" Value="0,0,1,0"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource PalisadeTextBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PalisadeHoverSubtleBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <MultiBinding Converter="{StaticResource MultiValueEqualityConverter}">
                                <Binding/>
                                <Binding Path="DataContext.SelectedMember" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            </MultiBinding>
                        </DataTrigger.Binding>
                        <Setter Property="BorderBrush" Value="{DynamicResource PalisadeAccentBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource PalisadeCardBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="RoundedTabHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatTabHeaderButtonStyle}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PalisadeHoverSubtleBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="CurrentTabHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatTabHeaderButtonStyle}"/>

        <!-- Standard -->
        <DataTemplate DataType="{x:Type viewModel:PalisadeViewModel}">
            <Grid AllowDrop="True" Background="{DynamicResource PalisadeControlBrush}">
                <Grid.Resources>
                    <helpers:BindingProxy x:Key="tabProxy" Data="{Binding}" />
                </Grid.Resources>
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static properties:Strings.MenuPaste}" Command="{Binding PasteShortcutCommand}"/>
                        <MenuItem Header="{x:Static properties:Strings.MenuSortByName}" Command="{Binding SortByNameCommand}"/>
                        <MenuItem Header="{x:Static properties:Strings.MenuDeleteSelection}" Command="{Binding DeleteSelectionCommand}"/>
                    </ContextMenu>
                </Grid.ContextMenu>
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Drop">
                        <i:InvokeCommandAction Command="{Binding DropShortcut}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Shortcuts}" Margin="20"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True"
                                 dd:DragDrop.DropHandler="{Binding}"
                                 dd:DragDrop.DragHandler="{Binding}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ContentControl>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:LaunchUriOrFileAction Path="{Binding UriOrFileAction}" />
                                        </i:EventTrigger>
                                        <i:EventTrigger EventName="MouseDown">
                                            <i:InvokeCommandAction Command="{Binding Path=Data.ClickShortcutCommand, Source={StaticResource tabProxy}}" CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <Border Margin="0,10" CornerRadius="4" Width="100">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{x:Static properties:Strings.MenuDelete}"
                                                          Command="{Binding Path=Data.RemoveSelectedShortcutCommand, Source={StaticResource tabProxy}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style>
                                                <Style.Triggers>
                                                    <Trigger Property="Border.IsMouseOver" Value="True">
                                                        <Setter Property="Border.Background" Value="{DynamicResource PalisadeCardHoverBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource MultiValueEqualityConverter}">
                                                                <Binding Mode="OneWay" />
                                                                <Binding Path="Data.SelectedShortcut" Source="{StaticResource tabProxy}" Mode="OneWay" />
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Border.Background" Value="{DynamicResource PalisadeCardHoverBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Cursor="Hand">
                                            <Image Source="{Binding IconPath, Converter={StaticResource PathToImage}}" Width="48" Height="48" Stretch="UniformToFill" Margin="5" />
                                            <TextBlock TextWrapping="NoWrap" TextAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding Name, Mode=OneWay}"
                                                       Foreground="{DynamicResource PalisadeTextBrush}"
                                                       HorizontalAlignment="Center" Margin="5,0,5,5" />
                                        </StackPanel>
                                    </Border>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <!-- Browse palisade (folder) -->
        <DataTemplate DataType="{x:Type viewModel:FolderPortalViewModel}">
            <Border CornerRadius="0" ClipToBounds="True" Background="{DynamicResource PalisadeControlBrush}">
                <Grid>
                    <Grid.Resources>
                        <helpers:BindingProxy x:Key="folderProxy" Data="{Binding}" />
                    </Grid.Resources>
                    <Grid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static properties:Strings.MenuNewFolder}" Command="{Binding CreateNewFolderCommand}"/>
                            <MenuItem Header="{x:Static properties:Strings.MenuNewTextFile}" Command="{Binding CreateNewFileCommand}"/>
                            <MenuItem Header="{x:Static properties:Strings.MenuPaste}" Command="{Binding PasteFromClipboardCommand}"/>
                            <Separator/>
                            <MenuItem Header="{x:Static properties:Strings.MenuRefresh}" Command="{Binding RefreshCommand}"/>
                            <MenuItem Header="{x:Static properties:Strings.MenuOpenInExplorer}" Command="{Binding OpenInExplorerCommand}"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                               Foreground="{DynamicResource PalisadeErrorBrush}"
                               FontSize="13"
                               Margin="15,10"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Items}" Margin="10"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      dd:DragDrop.IsDragSource="True"
                                      dd:DragDrop.IsDropTarget="True"
                                      dd:DragDrop.DropHandler="{Binding}"
                                      dd:DragDrop.DragHandler="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl>
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseDoubleClick">
                                                <i:InvokeCommandAction Command="{Binding Path=Data.NavigateIntoFolderCommand, Source={StaticResource folderProxy}}" CommandParameter="{Binding}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        <Border Margin="0,10" CornerRadius="4" Width="100">
                                            <Border.Style>
                                                <Style>
                                                    <Style.Triggers>
                                                        <Trigger Property="Border.IsMouseOver" Value="True">
                                                            <Setter Property="Border.Background" Value="{DynamicResource PalisadeCardHoverBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Cursor="Hand">
                                                <Image Source="{Binding IconPath, Converter={StaticResource PathToImage}}" Width="48" Height="48" Stretch="UniformToFill" Margin="5" />
                                                <TextBlock TextWrapping="NoWrap" TextAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding Name, Mode=OneWay}"
                                                           Foreground="{DynamicResource PalisadeTextBrush}" HorizontalAlignment="Center" Margin="5,0,5,5" ToolTip="{Binding Name, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Task -->
        <DataTemplate DataType="{x:Type viewModel:TaskPalisadeViewModel}">
            <Border Background="{DynamicResource PalisadeControlBrush}" Padding="10">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource PalisadeErrorBrush}"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                               Grid.Row="0" Margin="0,0,0,8" FontSize="11"/>
                    <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource PalisadeProgressBar}"/>
                        <TextBlock Text="{x:Static properties:Strings.LoadingEllipsis}" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource PalisadeTextBrush}" FontSize="11"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Text="{Binding SyncStatus}" FontSize="10" Foreground="{DynamicResource PalisadeSubtleBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,4"
                               Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="1" Text="{x:Static properties:Strings.EmptyNoTasks}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource PalisadeSubtleBrush}" FontStyle="Italic"
                               Visibility="{Binding HasNoTasks, Converter={StaticResource BoolToVis}}"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ActiveTasks}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent" BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="4"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource PalisadeListBoxItemStyle}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,0,0,2" CornerRadius="4"
                                        Background="{DynamicResource PalisadeCardBrush}" x:Name="TaskCard">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Completed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Top" Margin="0,2,0,0"
                                                  Command="{Binding DataContext.ToggleTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}"/>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Title, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PalisadeTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description, Mode=OneWay}" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PalisadeSubtleBrush}"
                                                       Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding DueDateDisplay, Mode=OneWay}" FontSize="11"
                                                       Foreground="{Binding DueDateColor}"
                                                       Visibility="{Binding DueDateDisplay, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="💾" ToolTip="{x:Static properties:Strings.TooltipSave}" Style="{StaticResource CircleButton}" Width="22" Height="22" Margin="0,0,2,0"
                                                    Command="{Binding DataContext.SaveTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                            <Button Content="🗑" ToolTip="{x:Static properties:Strings.TooltipDelete}" Style="{StaticResource CircleButton}" Width="22" Height="22"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="TaskCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TaskCard" Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Completed}" Value="True">
                                        <Setter TargetName="TaskCard" Property="Opacity" Value="0.5"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Content="{x:Static properties:Strings.EventButtonAddTask}" Command="{Binding AddTaskCommand}"
                            Style="{StaticResource PalisadeActionButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Calendar -->
        <DataTemplate DataType="{x:Type viewModel:CalendarPalisadeViewModel}">
            <Border Background="{DynamicResource PalisadeControlBrush}" CornerRadius="0" Padding="12">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource PalisadeErrorBrush}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Grid.Row="0" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                        <Button Grid.Column="0" Content="&lt;" Command="{Binding PreviousDayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="&gt;" Command="{Binding NextDayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding DateRangeDisplay}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource PalisadeTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="3" Content="⌂" ToolTip="{x:Static properties:Strings.TooltipToday}" Command="{Binding TodayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center" Margin="4,0,4,0"/>
                        <ComboBox Grid.Column="4" SelectedItem="{Binding ViewMode}" ItemsSource="{Binding ViewModes}"
                                  Width="75" Height="24" VerticalAlignment="Center"
                                  FontSize="11" Background="{DynamicResource PalisadeControlBrush}"
                                  Foreground="{DynamicResource PalisadeTextBrush}" BorderThickness="1"
                                  BorderBrush="{DynamicResource PalisadeBorderBrush}"/>
                    </Grid>
                    <StackPanel Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource PalisadeProgressBar}"/>
                        <TextBlock Text="{x:Static properties:Strings.LoadingEllipsis}" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource PalisadeTextBrush}"/>
                    </StackPanel>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Events}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="4"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource PalisadeListBoxItemStyle}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Visibility="{Binding DayHeader, Converter={StaticResource StringToVisibilityConverter}}"
                                            Margin="0,12,0,4" Padding="4,4"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DayHeaderDisplay}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PalisadeAccentBrush}"/>
                                    </Border>
                                    <Border BorderBrush="{DynamicResource PalisadeAccentBrush}" BorderThickness="3,0,0,0"
                                            Padding="10,8" Margin="0,0,0,2" Background="{DynamicResource PalisadeCardBrush}" CornerRadius="0,4,4,0"
                                            x:Name="EventCard">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Summary, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PalisadeTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="{Binding TimeDisplay, Mode=OneWay}" Margin="0,2,0,0" Foreground="{DynamicResource PalisadeSubtleBrush}" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Text="{Binding Location}" Visibility="{Binding Location, Converter={StaticResource StringToVisibilityConverter}}" FontSize="11" Foreground="{DynamicResource PalisadeSubtleBrush}" FontStyle="Italic" Margin="0,2,0,0"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="EventCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="EventCard" Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="2" Text="{x:Static properties:Strings.EmptyNoEvents}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource PalisadeSubtleBrush}" FontStyle="Italic"
                               Visibility="{Binding HasNoEvents, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Row="3" Content="{x:Static properties:Strings.EventButtonAdd}" Command="{Binding AddEventCommand}"
                            Style="{StaticResource PalisadeActionButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Mail -->
        <DataTemplate DataType="{x:Type viewModel:MailPalisadeViewModel}">
            <Border Background="{DynamicResource PalisadeControlBrush}" CornerRadius="0" Padding="12">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource PalisadeErrorBrush}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Grid.Row="0" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="LoadingPanel">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ProgressBar Style="{StaticResource PalisadeProgressBar}"/>
                    </StackPanel>
                    <Grid Grid.Row="1" x:Name="CountOnlyPanel">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLoading}" Value="False"/>
                                            <Condition Binding="{Binding DisplayMode}" Value="{x:Static model:MailDisplayMode.CountOnly}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <TextBlock Text="{Binding TotalUnreadCount, Mode=OneWay}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PalisadeTextBrush}"/>
                        <TextBlock Text="{Binding UnreadCountsDisplay, Mode=OneWay}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" Foreground="{DynamicResource PalisadeTextBrush}"/>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding RecentSubjects}" x:Name="SubjectsPanel"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLoading}" Value="False"/>
                                            <Condition Binding="{Binding DisplayMode}" Value="{x:Static model:MailDisplayMode.CountAndSubjects}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="4"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource PalisadeListBoxItemStyle}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="MailCard" BorderBrush="{DynamicResource PalisadeBorderBrush}" BorderThickness="0,0,0,1" Padding="6" Margin="0,0,0,4" Background="{DynamicResource PalisadeCardBrush}">
                                    <Grid RowDefinitions="Auto,Auto">
                                        <TextBlock Grid.Row="0" Text="{Binding Subject, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource PalisadeTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Sender, Mode=OneWay}" FontSize="11" Margin="0,2,0,0" Foreground="{DynamicResource PalisadeTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="1" HorizontalAlignment="Right" Text="{Binding Date, StringFormat='{}{0:g}', Mode=OneWay}" FontSize="11" Margin="0,2,0,0" Foreground="{DynamicResource PalisadeTextBrush}"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="MailCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MailCard" Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>
    <Border x:Name="LayoutRoot" CornerRadius="0" ClipToBounds="True">
        <DockPanel>
            <Grid DockPanel.Dock="Top" x:Name="Header" Height="32" MouseLeftButtonDown="Header_MouseLeftButtonDown" IsHitTestVisible="True" Background="{DynamicResource PalisadeWindowBrush}" ColumnDefinitions="Auto,*,Auto">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static properties:Strings.MenuEdit}" Command="{x:Static pal:PalisadesWpfCommands.OpenEditSelectedTabCommand}" CommandParameter="{Binding SelectedMember}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuDelete}" Command="{Binding Path=Data.DeletePalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding SelectedMember.Identifier}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewShortcutPalisade}" Command="{Binding Path=Data.NewPalisadeCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewBrowsePalisade}" Command="{Binding Path=Data.NewFolderPortalCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewTaskPalisade}" Command="{Binding Path=Data.NewTaskPalisadeCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewCalendarPalisade}" Command="{Binding Path=Data.NewCalendarPalisadeCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewMailPalisade}" Command="{Binding Path=Data.NewMailPalisadeCommand, Source={StaticResource proxy}}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuManageZimbraAccounts}" Command="{Binding Path=Data.ManageZimbraAccountsCommand, Source={StaticResource proxy}}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuLayouts}" SubmenuOpened="LayoutsSubmenu_SubmenuOpened">
                            <MenuItem Header="{x:Static properties:Strings.MenuSaveCurrentLayout}" Command="{Binding Path=Data.SaveSnapshotCommand, Source={StaticResource proxy}}" />
                            <Separator />
                            <MenuItem ItemsSource="{Binding Path=Data.RecentSnapshots, Source={StaticResource proxy}}">
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding Name}" />
                                        <Setter Property="Command" Value="{Binding Path=Data.RestoreSnapshotCommand, Source={StaticResource proxy}}" />
                                        <Setter Property="CommandParameter" Value="{Binding Id}" />
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{x:Static properties:Strings.MenuManageLayouts}" Command="{Binding Path=Data.ManageSnapshotsCommand, Source={StaticResource proxy}}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuAbout}" Command="{Binding Path=Data.OpenAboutCommand, Source={StaticResource proxy}}" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Button Grid.Column="0" x:Name="TitleBarMenuButton" Style="{StaticResource PalisadeNavButton}" Click="TitleBarMenuButton_Click" ToolTip="{x:Static properties:Strings.TooltipMenu}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE700;" FontSize="14" VerticalAlignment="Center"/>
                </Button>
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              PreviewMouseRightButtonDown="TabStrip_PreviewMouseRightButtonDown">
                    <ItemsControl ItemsSource="{Binding Members}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding TabBarLabel, Mode=OneWay}"
                                        Style="{DynamicResource CurrentTabHeaderButtonStyle}"
                                        Command="{Binding DataContext.SelectMemberCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{Binding TabBarLabel, Mode=OneWay}">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource PalisadeTextBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Button Grid.Column="2" Style="{StaticResource PalisadeNavButton}" Click="AddFolderPortalTab_Click" ToolTip="{x:Static properties:Strings.TooltipAddTabBrowseSameGroup}">
                    <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PalisadeTextBrush}" VerticalAlignment="Center"/>
                </Button>
            </Grid>
            <ContentControl Content="{Binding SelectedMember}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}" />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </DockPanel>
    </Border>
</Window>
