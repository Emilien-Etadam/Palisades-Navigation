<Window x:Class="Palisades.View.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:Palisades.ViewModel"
        xmlns:helpers="clr-namespace:Palisades.Helpers"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource PalisadeWindowBrush}"
        Title="About Palisades"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.DataContext>
        <viewModel:AboutViewModel />
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <StackPanel HorizontalAlignment="Center" Margin="36,0,36,20" TextElement.FontSize="18">
            <Label FontSize="48" HorizontalAlignment="Center" Content="Palisades"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label FontWeight="Bold" Content="{Binding Version}" />
                <Label Content="{Binding ReleaseDate}" />
            </StackPanel>
            <TextBlock TextAlignment="Center" Foreground="{DynamicResource PalisadeSubtleBrush}" FontSize="14" Margin="0,4,0,0"
                       Text="{Binding FrameworkRuntime}" />
            <TextBlock TextAlignment="Justify" TextWrapping="Wrap" Foreground="{DynamicResource PalisadeTextBrush}" Margin="0,16,0,0" Padding="8,0,8,0" FontSize="15">
                <Run Text="Maintained by " />
                <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://stouder.io/">
                    <Run Text="Xavier Stouder" />
                </helpers:HyperlinkCommander>
                <Run Text=". Released under the MIT licence. Report issues, check for updates, or contribute on the " />
                <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/Emilien-Etadam/Palisades-Navigation">
                    <Run Text="GitHub repository" />
                </helpers:HyperlinkCommander>
                <Run Text="." />
            </TextBlock>
            <StackPanel HorizontalAlignment="Stretch">
                <Label FontSize="22" HorizontalAlignment="Center" Content="Credits" Margin="0,18,0,0" />
                <TextBlock TextAlignment="Justify" TextWrapping="Wrap" Foreground="{DynamicResource PalisadeTextBrush}" Margin="0,4,0,8" Padding="8,0,8,0" FontSize="14">
                    Open-source libraries used by this application:
                </TextBlock>
                <ItemsControl>
                    <ItemsControl.Items>
                        <Label Padding="8,2,8,2" FontSize="14" HorizontalContentAlignment="Left">
                            <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/punker76/gong-wpf-dragdrop">GongSolutions.WPF.DragDrop</helpers:HyperlinkCommander>
                        </Label>
                        <Label Padding="8,2,8,2" FontSize="14" HorizontalContentAlignment="Left">
                            <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/Microsoft/XamlBehaviorsWpf">Microsoft.Xaml.Behaviors.Wpf</helpers:HyperlinkCommander>
                        </Label>
                        <Label Padding="8,2,8,2" FontSize="14" HorizontalContentAlignment="Left">
                            <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/lstratman/Ical.Net">Ical.Net</helpers:HyperlinkCommander>
                        </Label>
                        <Label Padding="8,2,8,2" FontSize="14" HorizontalContentAlignment="Left">
                            <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/jstedfast/MailKit">MailKit</helpers:HyperlinkCommander>
                        </Label>
                        <Label Padding="8,2,8,2" FontSize="14" HorizontalContentAlignment="Left">
                            <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/CommunityToolkit/WindowsCommunityToolkit">Microsoft.Toolkit.Uwp.Notifications</helpers:HyperlinkCommander>
                        </Label>
                        <Label Padding="8,2,8,2" FontSize="14" HorizontalContentAlignment="Left">
                            <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://sentry.io/">Sentry</helpers:HyperlinkCommander>
                        </Label>
                    </ItemsControl.Items>
                </ItemsControl>
                <Label FontSize="18" HorizontalAlignment="Center" Content="Inspired by" Margin="0,16,0,0" />
                <TextBlock TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource PalisadeTextBrush}" Margin="0,6,0,0" Padding="8,0,8,0" FontSize="14">
                    <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://github.com/Twometer/NoFences">
                        <Run Text="NoFences" />
                    </helpers:HyperlinkCommander>
                    <Run Text=" (Twometer) and " />
                    <helpers:HyperlinkCommander Foreground="{DynamicResource PalisadeAccentBrush}" Command="{Binding NavigateCommand}" CommandParameter="https://www.stardock.com/products/fences/">
                        <Run Text="Fences" />
                    </helpers:HyperlinkCommander>
                    <Run Text=" (Stardock)." />
                </TextBlock>
            </StackPanel>
            <Button Content="Close" HorizontalAlignment="Center" Margin="0,22,0,0" Padding="32,8" IsDefault="True" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
