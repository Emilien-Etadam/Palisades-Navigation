<Window x:Class="Palisades.View.CreateCalendarPalisadeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Palisades.Properties"
        Title="{x:Static properties:Strings.WindowTitleNewCalendarPalisade}" MinHeight="520" Height="600" MinWidth="480" Width="520"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Text="{x:Static properties:Strings.LabelTitle}" Grid.Row="0" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="PalisadeTitleTextBox" Grid.Row="1" Margin="0,0,0,10" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding PalisadeTitle, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelCaldavBaseUrl}" Grid.Row="2" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="3" Margin="0,0,0,6" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding CalDAVUrl, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static properties:Strings.TooltipCalDAVBaseUrlExample}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelUsername}" Grid.Row="4" Style="{StaticResource PalisadeDialogLabel}"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="5" Margin="0,0,0,6" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelPassword}" Grid.Row="6" Style="{StaticResource PalisadeDialogLabel}"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,8" Style="{StaticResource PalisadeDialogPasswordBox}" PasswordChanged="PasswordBox_PasswordChanged"/>
        <Button x:Name="LoadCalendarsButton" Grid.Row="8" Content="{x:Static properties:Strings.ButtonLoadCalendars}" Margin="0,0,0,8" Style="{StaticResource PalisadeDialogButton}" Click="LoadCalendarsButton_Click" HorizontalAlignment="Left"/>
        <TextBlock Text="{x:Static properties:Strings.LabelCalendarsToShow}" Grid.Row="9" Style="{StaticResource PalisadeDialogLabel}"/>
        <ListBox x:Name="CalendarsListBox" Grid.Row="10" Margin="0,0,0,8" Style="{StaticResource PalisadeDialogListBox}" SelectionMode="Multiple" DisplayMemberPath="DisplayName" SelectionChanged="CalendarsListBox_SelectionChanged"/>
        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Width="80" Margin="0,0,10,0" Style="{StaticResource PalisadeDialogButton}" Click="CancelButton_Click"/>
            <Button x:Name="CreateButton" Content="{x:Static properties:Strings.ButtonCreate}" Width="80" IsDefault="True" Style="{StaticResource PalisadeDialogButton}" Click="CreateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
