<Window x:Class="Palisades.View.EditFolderPortal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModel="clr-namespace:Palisades.ViewModel"
        xmlns:properties="clr-namespace:Palisades.Properties"
        Title="{x:Static properties:Strings.WindowTitleEditBrowsePalisade}"
        Width="400"
        SizeToContent="Height"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource PalisadeWindowBrush}"
        ResizeMode="NoResize">
    <Window.DataContext>
        <viewModel:FolderPortalViewModel />
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBox">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Margin" Value="0,5" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ColumnDefinitions="Auto,10,*" RowDefinitions="Auto,10,Auto,*">
        <TextBlock Text="{x:Static properties:Strings.LabelName}" Grid.Row="0" Style="{StaticResource PalisadeDialogLabel}" FontSize="24"/>
        <TextBox FontSize="24" Grid.Column="2" Grid.Row="0" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <TextBlock Text="{x:Static properties:Strings.LabelRootPath}" Grid.Row="2" Style="{StaticResource PalisadeDialogLabel}" FontSize="24"/>
        <TextBox FontSize="14" Grid.Row="2" Grid.Column="2" Style="{StaticResource PalisadeDialogTextBox}" Text="{Binding RootPath, Mode=OneWay}" IsReadOnly="True" HorizontalAlignment="Stretch" VerticalAlignment="Center" />

    </Grid>
</Window>
