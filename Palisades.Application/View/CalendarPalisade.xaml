<Window x:Class="Palisades.View.CalendarPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Palisades.Helpers"
        xmlns:converters="clr-namespace:Palisades.Converters"
        helpers:WindowBackdrop.IsEnabled="True"
        helpers:WindowSinker.AlwaysOnBottom="True"
        ShowInTaskbar="False"
        Title="Calendar palisade"
        Width="{Binding Width, Mode=TwoWay}"
        Height="{Binding Height, Mode=TwoWay}"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        Left="{Binding FenceX, Mode=TwoWay}"
        Top="{Binding FenceY, Mode=TwoWay}"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0" NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <helpers:BindingProxy x:Key="proxy" Data="{Binding}" />
        </ResourceDictionary>
    </Window.Resources>
    <Border x:Name="LayoutRoot" CornerRadius="0" ClipToBounds="True">
        <DockPanel>
            <Grid DockPanel.Dock="Top" x:Name="Header" Height="32" MouseLeftButtonDown="Header_MouseLeftButtonDown" IsHitTestVisible="True" Background="{DynamicResource PalisadeWindowBrush}" ColumnDefinitions="*,Auto">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Edit" Command="{Binding Path=Data.EditCalendarPalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                        <MenuItem Header="Refresh" Command="{Binding Path=Data.RefreshCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="Delete" Command="{Binding Path=Data.DeletePalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding Identifier}" />
                        <Separator />
                        <MenuItem Header="New shortcut palisade" Command="{Binding Path=Data.NewPalisadeCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="New browse palisade" Command="{Binding Path=Data.NewFolderPortalCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="New task palisade" Command="{Binding Path=Data.NewTaskPalisadeCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="New calendar palisade" Command="{Binding Path=Data.NewCalendarPalisadeCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="New mail palisade" Command="{Binding Path=Data.NewMailPalisadeCommand, Source={StaticResource proxy}}" />
                        <Separator />
                        <MenuItem Header="Manage Zimbra Accounts" Command="{Binding Path=Data.ManageZimbraAccountsCommand, Source={StaticResource proxy}}" />
                        <Separator />
                        <MenuItem Header="Layouts" SubmenuOpened="LayoutsSubmenu_SubmenuOpened">
                            <MenuItem Header="Save current layout..." Command="{Binding Path=Data.SaveSnapshotCommand, Source={StaticResource proxy}}" />
                            <Separator />
                            <MenuItem ItemsSource="{Binding Path=Data.RecentSnapshots, Source={StaticResource proxy}}">
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding Name}" />
                                        <Setter Property="Command" Value="{Binding Path=Data.RestoreSnapshotCommand, Source={StaticResource proxy}}" />
                                        <Setter Property="CommandParameter" Value="{Binding Id}" />
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Manage layouts..." Command="{Binding Path=Data.ManageSnapshotsCommand, Source={StaticResource proxy}}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="About" Command="{Binding Path=Data.OpenAboutCommand, Source={StaticResource proxy}}" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <TextBlock Grid.Column="0" Text="{Binding Name, Mode=OneWay}" Margin="8,0" Style="{StaticResource PalisadeHeaderText}"/>
                <Button Grid.Column="1" Content="🔄" ToolTip="Refresh" Command="{Binding RefreshCommand}" CommandParameter="{Binding}"
                        Style="{StaticResource CircleButton}" Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Center"/>
            </Grid>
            <Border DockPanel.Dock="Top" Background="{DynamicResource PalisadeControlBrush}" CornerRadius="0" Padding="12">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- Row 0 : Error -->
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource PalisadeErrorBrush}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Grid.Row="0" Margin="0,0,0,8"/>

                    <!-- Row 1 : Navigation bar — use Grid not StackPanel -->
                    <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                        <Button Grid.Column="0" Content="&lt;" Command="{Binding PreviousDayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="&gt;" Command="{Binding NextDayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding DateRangeDisplay}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource PalisadeTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="3" Content="⌂" ToolTip="Today" Command="{Binding TodayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center" Margin="4,0,4,0"/>
                        <ComboBox Grid.Column="4" SelectedItem="{Binding ViewMode}" ItemsSource="{Binding ViewModes}"
                                  Width="75" Height="24" VerticalAlignment="Center"
                                  FontSize="11" Background="{DynamicResource PalisadeControlBrush}"
                                  Foreground="{DynamicResource PalisadeTextBrush}" BorderThickness="1"
                                  BorderBrush="{DynamicResource PalisadeBorderBrush}"/>
                    </Grid>

                    <!-- Row 2 : Loading -->
                    <StackPanel Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource PalisadeProgressBar}"/>
                        <TextBlock Text="Chargement..." HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource PalisadeTextBrush}"/>
                    </StackPanel>

                    <!-- Row 2 : Event list -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding Events}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="4"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource PalisadeListBoxItemStyle}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Day header OUTSIDE the event card -->
                                    <Border Visibility="{Binding DayHeader, Converter={StaticResource StringToVisibilityConverter}}"
                                            Margin="0,12,0,4" Padding="4,4"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DayHeaderDisplay}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PalisadeAccentBrush}"/>
                                    </Border>
                                    <!-- Event card -->
                                    <Border BorderBrush="{DynamicResource PalisadeAccentBrush}" BorderThickness="3,0,0,0"
                                            Padding="10,8" Margin="0,0,0,2" Background="{DynamicResource PalisadeCardBrush}" CornerRadius="0,4,4,0"
                                            x:Name="EventCard">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Summary, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PalisadeTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="{Binding TimeDisplay, Mode=OneWay}" Margin="0,2,0,0" Foreground="{DynamicResource PalisadeSubtleBrush}" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Text="{Binding Location}" Visibility="{Binding Location, Converter={StaticResource StringToVisibilityConverter}}" FontSize="11" Foreground="{DynamicResource PalisadeSubtleBrush}" FontStyle="Italic" Margin="0,2,0,0"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="EventCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="EventCard" Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Row 2 : Empty state (on top when no events) -->
                    <TextBlock Grid.Row="2" Text="Aucun événement" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource PalisadeSubtleBrush}" FontStyle="Italic"
                               Visibility="{Binding HasNoEvents, Converter={StaticResource BoolToVis}}"/>

                    <!-- Row 3 : Add event button — rectangular, not CircleButton -->
                    <Button Grid.Row="3" Content="+ Event" Command="{Binding AddEventCommand}"
                            Style="{StaticResource PalisadeActionButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>
