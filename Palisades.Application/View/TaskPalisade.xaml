<Window x:Class="Palisades.View.TaskPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Palisades.View"
        mc:Ignorable="d"
        Title="TaskPalisade" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        MouseLeftButtonDown="Header_MouseLeftButtonDown">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Primary/MaterialDesignColor.DeepPurple.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignColors;component/Themes/Recommended/Accent/MaterialDesignColor.Lime.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="LayoutRoot" CornerRadius="20" ClipToBounds="True">
    <Grid>
        <!-- Header with drag handle -->
        <Border x:Name="Header" Background="{Binding HeaderColor}" CornerRadius="20,20,0,0" 
                Height="30" VerticalAlignment="Top" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="New Calendar Palisade" Command="{Binding NewCalendarPalisadeCommand}"/>
                    <MenuItem Header="New Mail Palisade" Command="{Binding NewMailPalisadeCommand}"/>
                    <Separator/>
                    <MenuItem Header="Layouts" SubmenuOpened="LayoutsSubmenu_SubmenuOpened">
                        <MenuItem Header="Save current layout..." Command="{Binding SaveSnapshotCommand}"/>
                        <Separator/>
                        <MenuItem ItemsSource="{Binding RecentSnapshots}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Name}"/>
                                    <Setter Property="Command" Value="{Binding DataContext.RestoreSnapshotCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding Id}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Manage layouts..." Command="{Binding ManageSnapshotsCommand}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Manage Zimbra Accounts" Command="{Binding ManageZimbraAccountsCommand}"/>
                </ContextMenu>
            </Border.ContextMenu>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" Foreground="{Binding TitleColor}" 
                           VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
                <TextBlock Text="{Binding SyncStatus}" Foreground="{Binding LabelsColor}" 
                           VerticalAlignment="Center" Margin="20,0,0,0" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="🔄" ToolTip="Force Sync" Command="{Binding ForceSyncCommand}" 
                            Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                            Margin="0,0,5,0" Width="24" Height="24"/>
                    <Button Content="⚙" ToolTip="Settings" Command="{Binding ShowSettingsCommand}" 
                            CommandParameter="{Binding}" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                            Width="24" Height="24"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content area -->
        <Border Background="{Binding BodyColor}" CornerRadius="0,0,20,20" 
                Margin="0,30,0,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Error message area -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" 
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" 
                           Grid.Row="0" Margin="0,0,0,10"/>

                <!-- Tasks list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Tasks}" x:Name="TasksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Task completion checkbox -->
                                        <CheckBox IsChecked="{Binding Completed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  VerticalAlignment="Center" Grid.Column="0" 
                                                  Command="{Binding DataContext.ToggleTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                  CommandParameter="{Binding}"/>

                                        <!-- Task details -->
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                                       Foreground="{Binding DataContext.LabelsColor, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" 
                                                       Foreground="{Binding DataContext.LabelsColor, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                       Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Due: {0:d}'}" 
                                                       Foreground="{Binding DataContext.LabelsColor, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                       Visibility="{Binding DueDate, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <!-- Task actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="📝" ToolTip="Edit" 
                                                    Command="{Binding DataContext.SaveTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                                                    Width="24" Height="24" Margin="0,0,5,0"/>
                                            <Button Content="🗑" ToolTip="Delete" 
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                                                    Width="24" Height="24"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Loading indicator -->
                <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource MultiValueEqualityConverter}, ConverterParameter='True,Visible;False,Collapsed'}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="20"/>
                    <TextBlock Text="Loading tasks..." HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Sync indicator -->
                <StackPanel Grid.Row="1" Visibility="{Binding IsSyncing, Converter={StaticResource MultiValueEqualityConverter}, ConverterParameter='True,Visible;False,Collapsed'}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="20"/>
                    <TextBlock Text="Syncing with CalDAV..." HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Add task button -->
                <Button Grid.Row="2" Content="➕ Add Task" Command="{Binding AddTaskCommand}" 
                        HorizontalAlignment="Right" Margin="0,10,0,0" 
                        Style="{StaticResource MaterialDesignFloatingActionButton}" 
                        Width="48" Height="48"/>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>