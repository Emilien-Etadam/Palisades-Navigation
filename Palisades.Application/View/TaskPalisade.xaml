<Window x:Class="Palisades.View.TaskPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Palisades.Helpers"
        xmlns:converters="clr-namespace:Palisades.Converters"
        Title="TaskPalisade"
        helpers:WindowBackdrop.IsEnabled="True"
        helpers:WindowSinker.AlwaysOnBottom="True"
        ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Width="{Binding Width, Mode=TwoWay}"
        Height="{Binding Height, Mode=TwoWay}"
        Left="{Binding FenceX, Mode=TwoWay}"
        Top="{Binding FenceY, Mode=TwoWay}"
        ResizeMode="CanResize"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0" NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <helpers:BindingProxy x:Key="proxy" Data="{Binding}"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="LayoutRoot" CornerRadius="0" ClipToBounds="True">
    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Edit" Command="{Binding Path=Data.EditTaskPalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}"/>
                <MenuItem Header="Delete" Command="{Binding Path=Data.DeletePalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding Identifier}"/>
                <Separator/>
                <MenuItem Header="New fence" Command="{Binding Path=Data.NewPalisadeCommand, Source={StaticResource proxy}}"/>
                <MenuItem Header="New Folder Portal" Command="{Binding Path=Data.NewFolderPortalCommand, Source={StaticResource proxy}}"/>
                <MenuItem Header="New Task Palisade" Command="{Binding Path=Data.NewTaskPalisadeCommand, Source={StaticResource proxy}}"/>
                <MenuItem Header="New Calendar Palisade" Command="{Binding Path=Data.NewCalendarPalisadeCommand, Source={StaticResource proxy}}"/>
                <MenuItem Header="New Mail Palisade" Command="{Binding Path=Data.NewMailPalisadeCommand, Source={StaticResource proxy}}"/>
                <Separator/>
                <MenuItem Header="Manage Zimbra Accounts" Command="{Binding Path=Data.ManageZimbraAccountsCommand, Source={StaticResource proxy}}"/>
                <Separator/>
                <MenuItem Header="Layouts" SubmenuOpened="LayoutsSubmenu_SubmenuOpened">
                    <MenuItem Header="Save current layout..." Command="{Binding Path=Data.SaveSnapshotCommand, Source={StaticResource proxy}}"/>
                    <Separator/>
                    <MenuItem ItemsSource="{Binding Path=Data.RecentSnapshots, Source={StaticResource proxy}}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding Name}"/>
                                <Setter Property="Command" Value="{Binding Path=Data.RestoreSnapshotCommand, Source={StaticResource proxy}}"/>
                                <Setter Property="CommandParameter" Value="{Binding Id}"/>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Manage layouts..." Command="{Binding Path=Data.ManageSnapshotsCommand, Source={StaticResource proxy}}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="About" Command="{Binding Path=Data.OpenAboutCommand, Source={StaticResource proxy}}"/>
            </ContextMenu>
        </Grid.ContextMenu>
        <Border x:Name="Header" Background="{DynamicResource PalisadeWindowBrush}" CornerRadius="0" 
                Height="32" VerticalAlignment="Top" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Name, Mode=OneWay}" Foreground="{DynamicResource PalisadeTextBrush}" 
                           VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
                <TextBlock Text="{Binding SyncStatus, Mode=OneWay}" Foreground="{DynamicResource PalisadeTextBrush}" 
                           VerticalAlignment="Center" Margin="20,0,0,0" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="🔄" ToolTip="Force Sync" Command="{Binding ForceSyncCommand}" 
                            Style="{StaticResource CircleButton}" 
                            Margin="0,0,5,0" Width="24" Height="24"/>
                    <Button Content="⚙" ToolTip="Settings" Command="{Binding ShowSettingsCommand}" 
                            CommandParameter="{Binding}" Style="{StaticResource CircleButton}" 
                            Width="24" Height="24"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Border Background="{DynamicResource PalisadeControlBrush}" CornerRadius="0" 
                Margin="0,30,0,0" Padding="10">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource PalisadeErrorBrush}" 
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" 
                           Grid.Row="0" Margin="0,10"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" x:Name="TasksList"
                         Visibility="{Binding HasMultipleLists, Converter={StaticResource InverseBoolToVis}}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                    <CheckBox IsChecked="{Binding Completed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                              VerticalAlignment="Center" Grid.Column="0" 
                                              Command="{Binding DataContext.ToggleTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                              CommandParameter="{Binding}"/>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Title, Mode=OneWay}" FontWeight="Bold" 
                                                   Foreground="{DynamicResource PalisadeTextBrush}"/>
                                        <TextBlock Text="{Binding Description, Mode=OneWay}" TextWrapping="Wrap" 
                                                   Foreground="{DynamicResource PalisadeTextBrush}" 
                                                   Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding DueDate, StringFormat='Due: {0:d}', Mode=OneWay}" 
                                                   Foreground="{DynamicResource PalisadeTextBrush}" 
                                                   Visibility="{Binding DueDate, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="📝" ToolTip="Edit" 
                                                Command="{Binding DataContext.SaveTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                CommandParameter="{Binding}" 
                                                Style="{StaticResource CircleButton}" 
                                                Width="24" Height="24" Margin="0,0,5,0"/>
                                        <Button Content="🗑" ToolTip="Delete" 
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                                CommandParameter="{Binding}" 
                                                Style="{StaticResource CircleButton}" 
                                                Width="24" Height="24"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TabControl Grid.Row="1" ItemsSource="{Binding TaskTabs}" SelectedItem="{Binding SelectedTaskTab, Mode=TwoWay}"
                            Visibility="{Binding HasMultipleLists, Converter={StaticResource BoolToVis}}"
                            Background="Transparent" BorderThickness="0">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PalisadeTextBrush}"/>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <ListBox ItemsSource="{Binding Tasks}"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Background="Transparent" BorderThickness="0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource PalisadeBorderBrush}" BorderThickness="0,0,0,1" Padding="5">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <CheckBox IsChecked="{Binding Completed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center" Grid.Column="0"/>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Title, Mode=OneWay}" FontWeight="Bold"
                                                               Foreground="{DynamicResource PalisadeTextBrush}"/>
                                                    <TextBlock Text="{Binding Description, Mode=OneWay}" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource PalisadeSubtleBrush}"
                                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding DueDate, StringFormat='Due: {0:d}', Mode=OneWay}"
                                                               Foreground="{DynamicResource PalisadeSubtleBrush}"
                                                               Visibility="{Binding DueDate, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
                <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="20"/>
                    <TextBlock Text="Loading tasks..." HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="20"/>
                    <TextBlock Text="Syncing with CalDAV..." HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
                <Button Grid.Row="2" Content="➕ Add Task" Command="{Binding AddTaskCommand}" 
                        HorizontalAlignment="Right" Margin="0,10,0,0" 
                        Style="{StaticResource CircleButtonLarge}" 
                        Width="48" Height="48"/>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
