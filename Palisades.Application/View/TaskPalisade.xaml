<Window x:Class="Palisades.View.TaskPalisade"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Palisades.Helpers"
        xmlns:properties="clr-namespace:Palisades.Properties"
        xmlns:converters="clr-namespace:Palisades.Converters"
        Title="{x:Static properties:Strings.AddTabTaskPalisade}"
        helpers:WindowBackdrop.IsEnabled="True"
        helpers:WindowSinker.AlwaysOnBottom="True"
        ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Width="{Binding Width, Mode=TwoWay}"
        Height="{Binding Height, Mode=TwoWay}"
        Left="{Binding FenceX, Mode=TwoWay}"
        Top="{Binding FenceY, Mode=TwoWay}"
        ResizeMode="CanResize"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0" NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
                <ResourceDictionary Source="/View/Styles/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <converters:InverseEmptyStringToVisibilityConverter x:Key="InverseEmptyStringToVisibilityConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:MultiValueEqualityConverter x:Key="MultiValueEqualityConverter"/>
            <helpers:BindingProxy x:Key="proxy" Data="{Binding}"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="LayoutRoot" CornerRadius="0" ClipToBounds="True">
    <DockPanel>
        <!-- Header : tabs if multi-list, else just sync status + buttons -->
        <Grid DockPanel.Dock="Top" x:Name="Header" Height="32" MouseLeftButtonDown="Header_MouseLeftButtonDown"
              IsHitTestVisible="True" Background="{DynamicResource PalisadeWindowBrush}"
              ColumnDefinitions="*,Auto,Auto,Auto">
            <Grid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{x:Static properties:Strings.MenuEdit}" Command="{Binding Path=Data.EditTaskPalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}"/>
                    <MenuItem Header="{x:Static properties:Strings.MenuDelete}" Command="{Binding Path=Data.DeletePalisadeCommand, Source={StaticResource proxy}}" CommandParameter="{Binding Identifier}"/>
                    <Separator/>
                    <MenuItem Header="{x:Static properties:Strings.MenuNewShortcutPalisade}" Command="{Binding Path=Data.NewPalisadeCommand, Source={StaticResource proxy}}"/>
                    <MenuItem Header="{x:Static properties:Strings.MenuNewBrowsePalisade}" Command="{Binding Path=Data.NewFolderPortalCommand, Source={StaticResource proxy}}"/>
                    <MenuItem Header="{x:Static properties:Strings.MenuNewTaskPalisade}" Command="{Binding Path=Data.NewTaskPalisadeCommand, Source={StaticResource proxy}}"/>
                    <MenuItem Header="{x:Static properties:Strings.MenuNewCalendarPalisade}" Command="{Binding Path=Data.NewCalendarPalisadeCommand, Source={StaticResource proxy}}"/>
                    <MenuItem Header="{x:Static properties:Strings.MenuNewMailPalisade}" Command="{Binding Path=Data.NewMailPalisadeCommand, Source={StaticResource proxy}}"/>
                    <Separator/>
                    <MenuItem Header="{x:Static properties:Strings.MenuManageZimbraAccounts}" Command="{Binding Path=Data.ManageZimbraAccountsCommand, Source={StaticResource proxy}}"/>
                    <Separator/>
                    <MenuItem Header="{x:Static properties:Strings.MenuLayouts}" SubmenuOpened="LayoutsSubmenu_SubmenuOpened">
                        <MenuItem Header="{x:Static properties:Strings.MenuSaveCurrentLayout}" Command="{Binding Path=Data.SaveSnapshotCommand, Source={StaticResource proxy}}"/>
                        <Separator/>
                        <MenuItem ItemsSource="{Binding Path=Data.RecentSnapshots, Source={StaticResource proxy}}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource PalisadeMenuItemStyle}">
                                    <Setter Property="Header" Value="{Binding Name}"/>
                                    <Setter Property="Command" Value="{Binding Path=Data.RestoreSnapshotCommand, Source={StaticResource proxy}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding Id}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="{x:Static properties:Strings.MenuManageLayouts}" Command="{Binding Path=Data.ManageSnapshotsCommand, Source={StaticResource proxy}}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="{x:Static properties:Strings.MenuAbout}" Command="{Binding Path=Data.OpenAboutCommand, Source={StaticResource proxy}}"/>
                </ContextMenu>
            </Grid.ContextMenu>

            <!-- Col 0 : Tab buttons OR sync status -->
            <ItemsControl Grid.Column="0" ItemsSource="{Binding TaskTabs}"
                          Visibility="{Binding HasMultipleLists, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding DisplayName}" Margin="0,0,1,0" Padding="10,0" Height="32"
                                FontSize="12" Cursor="Hand"
                                Foreground="{DynamicResource PalisadeTextBrush}"
                                Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource PalisadeHoverSubtleBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource MultiValueEqualityConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.SelectedTaskTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PalisadeAccentBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource PalisadeCardBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Fallback single-list : sync status text -->
            <TextBlock Grid.Column="0" Text="{Binding SyncStatus, Mode=OneWay}" FontSize="11"
                       Foreground="{DynamicResource PalisadeSubtleBrush}" VerticalAlignment="Center" Margin="10,0"
                       Visibility="{Binding HasMultipleLists, Converter={StaticResource InverseBoolToVis}}" TextTrimming="CharacterEllipsis"/>

            <!-- Col 1,2,3 : action buttons -->
            <Button Grid.Column="1" Content="⟳" ToolTip="{x:Static properties:Strings.TooltipForceSync}" Command="{Binding ForceSyncCommand}"
                    Style="{StaticResource CircleButton}" Width="24" Height="24" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="⚙" ToolTip="{x:Static properties:Strings.TooltipSettings}" Command="{Binding ShowSettingsCommand}" CommandParameter="{Binding}"
                    Style="{StaticResource CircleButton}" Width="24" Height="24" VerticalAlignment="Center" Margin="2,0"/>
            <Button Grid.Column="3" Content="✎" ToolTip="{x:Static properties:Strings.TooltipEdit}" Command="{Binding EditTaskPalisadeCommand}" CommandParameter="{Binding}"
                    Style="{StaticResource CircleButton}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
        </Grid>

        <!-- Content area -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PalisadeControlBrush}" Padding="10">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Row 0 : Error -->
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource PalisadeErrorBrush}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                           Grid.Row="0" Margin="0,0,0,8" FontSize="11"/>

                <!-- Row 1 : Loading -->
                <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource PalisadeProgressBar}"/>
                    <TextBlock Text="{x:Static properties:Strings.TaskLoadingEllipsis}" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource PalisadeTextBrush}" FontSize="11"/>
                </StackPanel>

                <!-- Row 1 : Syncing indicator (subtle, non-blocking) -->
                <TextBlock Grid.Row="1" Text="{Binding SyncStatus}" FontSize="10" Foreground="{DynamicResource PalisadeSubtleBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,4"
                           Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>

                <!-- Row 1 : Empty state -->
                <TextBlock Grid.Row="1" Text="{x:Static properties:Strings.EmptyNoTasks}" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource PalisadeSubtleBrush}" FontStyle="Italic"
                           Visibility="{Binding HasNoTasks, Converter={StaticResource BoolToVis}}"/>

                <!-- Row 1 : Task list (single or selected tab) -->
                <ListBox Grid.Row="1" ItemsSource="{Binding FilteredActiveTasks}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource PalisadeScrollBarStyle}"/>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource PalisadeListBoxItemStyle}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="0,0,0,2" CornerRadius="4"
                                    Background="{DynamicResource PalisadeCardBrush}" x:Name="TaskCard">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Completed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Top" Margin="0,2,0,0"
                                              Command="{Binding DataContext.ToggleTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                              CommandParameter="{Binding}"/>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Title, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PalisadeTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description, Mode=OneWay}" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource PalisadeSubtleBrush}"
                                                   Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding DueDateDisplay, Mode=OneWay}" FontSize="11"
                                                   Foreground="{Binding DueDateColor}"
                                                   Visibility="{Binding DueDateDisplay, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="💾" ToolTip="{x:Static properties:Strings.TooltipSave}" Style="{StaticResource CircleButton}" Width="22" Height="22" Margin="0,0,2,0"
                                                Visibility="{Binding CalDAVId, Converter={StaticResource InverseEmptyStringToVisibilityConverter}}"
                                                Command="{Binding DataContext.SaveTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                        <Button Content="🗑" ToolTip="{x:Static properties:Strings.TooltipHideTask}" Style="{StaticResource CircleButton}" Width="22" Height="22"
                                                Command="{Binding DataContext.HideTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="TaskCard" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TaskCard" Property="Background" Value="{DynamicResource PalisadeCardHoverBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding Completed}" Value="True">
                                    <Setter TargetName="TaskCard" Property="Opacity" Value="0.5"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Row 2 : Add task button (same style as calendar) -->
                <Button Grid.Row="2" Content="{x:Static properties:Strings.EventButtonAddTask}" Command="{Binding AddTaskCommand}"
                        Style="{StaticResource PalisadeActionButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
            </Grid>
        </Border>
    </DockPanel>
    </Border>
</Window>
