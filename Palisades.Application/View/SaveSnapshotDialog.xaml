<Window x:Class="Palisades.View.SaveSnapshotDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Save current layout"
        Width="400"
        SizeToContent="Height"
        Background="{DynamicResource PalisadeWindowBrush}"
        TextElement.Foreground="{DynamicResource PalisadeTextBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/PalisadeStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="25" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Layout name" Grid.Row="0" Style="{StaticResource PalisadeDialogLabel}" />
        <TextBox x:Name="NameTextBox" Grid.Row="2" FontSize="14" Style="{StaticResource PalisadeDialogTextBox}" />
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource PalisadeDialogButton}" Click="CancelButton_Click" Margin="0,0,10,0" />
            <Button Content="Save" Style="{StaticResource PalisadeDialogButton}" Click="SaveButton_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
