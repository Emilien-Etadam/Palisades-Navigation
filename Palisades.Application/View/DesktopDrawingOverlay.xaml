<Window x:Class="Palisades.View.DesktopDrawingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="False"
        ResizeMode="NoResize" x:Name="RootWindow">
    <Canvas x:Name="DrawCanvas" Background="#00000000">
        <Rectangle x:Name="SelectionRect" Visibility="Collapsed"
                   Stroke="#80FFFFFF" StrokeThickness="2" StrokeDashArray="4 2"
                   Fill="#260077FF"/>
        <TextBlock x:Name="DimensionsLabel" Visibility="Collapsed"
                   FontSize="12" Foreground="White" Background="#80000000" Padding="4,2"/>
    </Canvas>
</Window>
