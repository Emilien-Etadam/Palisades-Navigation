<Window x:Class="Palisades.View.ManageAccountsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Manage Zimbra Accounts" Height="400" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="12" RowDefinitions="Auto,*,Auto">
        <TextBlock Text="Zimbra accounts (CalDAV / Mail)" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ListBox x:Name="AccountsListBox" Grid.Row="1" Margin="0,0,0,10" SelectionChanged="AccountsListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Email}" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Server}" Foreground="Gray" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding LastTestStatus}" Foreground="Green" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="AddButton" Content="Add" Width="70" Margin="0,0,8,0" Click="AddButton_Click"/>
            <Button x:Name="EditButton" Content="Edit" Width="70" Margin="0,0,8,0" Click="EditButton_Click" IsEnabled="False"/>
            <Button x:Name="TestButton" Content="Test" Width="70" Margin="0,0,8,0" Click="TestButton_Click" IsEnabled="False"/>
            <Button x:Name="DeleteButton" Content="Delete" Width="70" Margin="0,0,8,0" Click="DeleteButton_Click" IsEnabled="False"/>
            <Button Content="Close" Width="70" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
